{
	"name": "klip",
	"version": "0.1.0",
	"private": true,
	"description": "A modern, cross-platform clipboard manager.",
	"license": "MIT",
	"engines": {
		"node": ">=22 <23"
	},
	"scripts": {
		"prepare": "husky install",
		"dev": "vite",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "node scripts/typecheck.mjs",
		"test": "node scripts/test.mjs",
		"test:e2e": "node scripts/test-e2e.mjs",
		"test:desktop": "bash scripts/test-desktop.sh",
		"test:coverage": "node scripts/test-coverage.mjs",
		"build": "node scripts/build.mjs",
		"cargo:check": "node scripts/cargo-check.mjs",
		"qa": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build && npm run test:coverage && npm run cargo:check",
		"preview": "vite preview",
		"precommit": "lint-staged",
		"commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
		"dev:desktop": "tauri dev",
		"build:desktop": "tauri build --debug --no-bundle",
		"build:desktop:bundle": "tauri build --ci --no-sign",
		"build:desktop:bundle:macos": "tauri build --ci --no-sign --bundles app,dmg",
		"build:desktop:bundle:macos:signed": "tauri build --ci --bundles app,dmg",
		"build:desktop:bundle:windows": "tauri build --ci --no-sign --bundles nsis",
		"tauri:info": "tauri info"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"react": "^19.1.1",
		"react-dom": "^19.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@playwright/test": "^1.58.2",
		"@tauri-apps/cli": "^2.10.0",
		"@types/react": "^19.1.12",
		"@types/react-dom": "^19.1.9",
		"@vitejs/plugin-react": "^5.0.2",
		"@vitest/coverage-v8": "^3.2.4",
		"husky": "^8.0.3",
		"lint-staged": "^15.5.0",
		"typescript": "^5.9.2",
		"vite": "^7.1.5",
		"vitest": "^3.2.4"
	}
}
