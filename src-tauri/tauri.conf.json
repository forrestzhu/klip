{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Klip",
	"version": "0.1.0",
	"identifier": "com.forrestzhu.klip",
	"build": {
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Klip",
				"width": 340,
				"height": 720,
				"decorations": false,
				"resizable": true,
				"transparent": true
			}
		]
	},
	"bundle": {
		"active": true
	}
}
