{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"useDefineForClassFields": true,
		"allowJs": false,
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"include": ["src", "tests", "vite.config.ts", "vitest.config.ts"]
}
